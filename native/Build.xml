<xml>
    <include name="${HXCPP}/build-tool/BuildCommon.xml"/>
    
    <files id="native">
        <compilerflag value="-I../../native/include"/>
        <file name="../../native/src/fifo_native.cpp"/>
        <file name="../../native/src/network_native.cpp"/>
        <file name="../../native/src/process_native.cpp"/>
        <file name="../../native/src/shm_native.cpp"/>
        <file name="../../native/src/info_native.cpp"/>
        <file name="../../native/src/fs_native.cpp"/>
        <file name="../../native/src/sync_native.cpp"/>
        <file name="../../native/src/proc_native.cpp"/>
        <file name="../../native/src/time_native.cpp"/>
        <file name="../../native/src/console_native.cpp"/>
        <file name="../../native/src/signal_native.cpp"/>
        <file name="../../native/src/rt_native.cpp"/>
        <file name="../../native/src/io_native.cpp"/>
        <file name="../../native/src/random_native.cpp"/>
    </files>

    <files id="haxe">
        <compilerflag value="-I../../native/include"/>
    </files>

    <target id="haxe">
        <files id="native"/>
        <lib name="ws2_32.lib" if="windows"/>
        <lib name="iphlpapi.lib" if="windows"/>
        <lib name="advapi32.lib" if="windows"/>
        <lib name="shlwapi.lib" if="windows"/>
        <lib name="psapi.lib" if="windows"/>
        <lib name="bcrypt.lib" if="windows"/>
        <lib name="-lrt" if="linux"/>
        <linkerflag value="-framework" if="macos"/>
        <linkerflag value="CoreServices" if="macos"/>
    </target>
</xml>
