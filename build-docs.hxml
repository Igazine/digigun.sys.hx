-cp test
-cp src
-main Docs
-xml docs/doc.xml
-D doc-gen
-D no-compilation
-D DIGIGUN.SYS.PURE_ALLOC
-D DIGIGUN.SYS.UNSAFE_MEMORY_ACCESS
--macro include('digigun.sys', true)
--dce no
--cpp bin/docs
--debug
--cmd haxelib run dox -i docs -o docs --title "digigun.sys.hx - API Documentation" --toplevel-package digigun.sys -D website "https://igazine.github.io/digigun.sys.hx/"